# Django
SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_SETTINGS_MODULE=config.settings.development

# Database
DATABASE_URL=postgres://postgres:postgres@db:5432/legal_crm
POSTGRES_DB=legal_crm
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Frontend
VITE_API_BASE_URL=http://localhost:8000

# Storage
USE_S3=False
MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=minio-password
MINIO_STORAGE_BUCKET_NAME=legal-crm-media
AWS_S3_ACCESS_KEY_ID=admin
AWS_S3_SECRET_ACCESS_KEY=minio-password
AWS_STORAGE_BUCKET_NAME=legal-crm-media
AWS_S3_ENDPOINT_URL=http://minio:9000
AWS_S3_REGION_NAME=us-east-1
